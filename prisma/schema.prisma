generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String?
  passwordHash  String
  name          String
  role          String    @default("GUARDIAN") // GUARDIAN, CAREGIVER, ADMIN
  profileImage  String?
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guardianProfile  GuardianProfile?
  caregiverProfile CaregiverProfile?
  notifications    Notification[]
  sentMessages     InterviewMessage[]
  bookmarks        Bookmark[]
  passes           Pass[]
  subscriptions    Subscription[]
  payments         Payment[]
  notices          Notice[]           @relation("NoticeAuthor")
  educationEnrollments EducationEnrollment[]
  reportsMade      Report[]           @relation("Reporter")
  reportsReceived  Report[]           @relation("ReportTarget")
  institutionMemberships InstitutionMember[]
  institutionStaff       InstitutionStaff[]   @relation("InstitutionCaregiver")

  @@index([phone])
  @@index([role])
}

// ─── Guardian (보호자) ───

model GuardianProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  region       String  @default("")
  address      String?
  introduction String?
  relationship String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careRecipients    CareRecipient[]
  matchesAsGuardian Match[]            @relation("MatchGuardian")
  reviewsWritten    Review[]           @relation("ReviewAuthor")
  coGuardians       CoGuardian[]       @relation("CoGuardianOwner")
  coGuardianAccess  CoGuardian[]       @relation("CoGuardianMember")
  emergencyCares    EmergencyCare[]

  @@index([region])
}

model CoGuardian {
  id          String          @id @default(cuid())
  ownerId     String
  owner       GuardianProfile @relation("CoGuardianOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberId    String
  member      GuardianProfile @relation("CoGuardianMember", fields: [memberId], references: [id], onDelete: Cascade)
  permission  String          @default("READ") // READ, WRITE
  inviteEmail String?
  status      String          @default("PENDING") // PENDING, ACCEPTED, REJECTED

  createdAt DateTime @default(now())

  @@unique([ownerId, memberId])
  @@index([ownerId])
  @@index([memberId])
}

// ─── Caregiver (요양보호사) ───

model CaregiverProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender            String
  birthDate         DateTime?
  region            String  @default("")
  address           String?
  introduction      String?
  experience        String?
  experienceYears   Int     @default(0)
  education         String?
  hourlyRate        Int     @default(15000)
  additionalRate    Int     @default(0)
  caregiverType     String  @default("CARE_WORKER")
  serviceCategories String  @default("[]")
  specialties       String  @default("[]")
  maxRecipients     Int     @default(1)
  canDrive          Boolean @default(false)
  nonsmoker         Boolean @default(true)
  licenseNumber     String?
  licenseVerified   Boolean @default(false)
  idVerified        Boolean @default(false)
  backgroundCheck   String  @default("PENDING")
  averageRating     Float   @default(0)
  totalReviews      Int     @default(0)
  totalCares        Int     @default(0)
  responseRate      Float   @default(0)
  // Grade system (등급 시스템)
  grade             String  @default("NEWBIE") // NEWBIE, GENERAL, SKILLED, EXPERT, MASTER
  gradePoints       Int     @default(0)
  videoIntroUrl     String?
  profileCompleteness Int   @default(0) // 0-100%
  // Certification workflow (7단계 인증)
  certStep          Int     @default(0) // 0-7 현재 완료 단계

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilities     Availability[]
  certificates       Certificate[]
  matchesAsCaregiver Match[]           @relation("MatchCaregiver")
  careSessions       CareSession[]     @relation("CareSessionCaregiver")
  reviewsReceived    Review[]          @relation("ReviewTarget")
  bookmarkedBy       Bookmark[]
  settlements        Settlement[]
  emergencyCareMatches EmergencyCareMatch[]

  @@index([region])
  @@index([hourlyRate])
  @@index([averageRating])
  @@index([caregiverType])
  @@index([grade])
}

// ─── Care Recipient (어르신/돌봄대상자) ───

model CareRecipient {
  id               String  @id @default(cuid())
  guardianId       String
  guardian         GuardianProfile @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  name             String
  gender           String
  birthYear        Int
  careLevel        String?
  diseases         String  @default("[]")
  mobilityLevel    String  @default("INDEPENDENT")
  weight           Float?
  height           Float?
  specialNotes     String?
  medications      String?
  emergencyContact String?
  address          String?
  profileImage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careSessionRecipients CareSessionRecipient[]
  matchRecipients       MatchRecipient[]

  @@index([guardianId])
}

// ─── Scheduling ───

model Availability {
  id          String           @id @default(cuid())
  caregiverId String
  caregiver   CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  dayOfWeek   String
  startTime   String
  endTime     String
  isActive    Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([caregiverId, dayOfWeek, startTime])
  @@index([caregiverId])
}

// ─── Certification (자격 인증) ───

model Certificate {
  id                  String           @id @default(cuid())
  caregiverId         String
  caregiver           CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  name                String
  certType            String           @default("OTHER") // CARE_WORKER_LICENSE, NURSING_AIDE_LICENSE, etc.
  step                Int              @default(0) // 7단계 중 몇 단계 인증인지
  issuingOrganization String
  issueDate           DateTime
  expirationDate      DateTime?
  certificateNumber   String?
  imageUrl            String?
  verificationStatus  String           @default("PENDING")
  verifiedAt          DateTime?
  rejectionReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caregiverId])
  @@index([certType])
}

// ─── Matching (매칭) ───

model Match {
  id              String          @id @default(cuid())
  guardianId      String
  guardian         GuardianProfile  @relation("MatchGuardian", fields: [guardianId], references: [id])
  caregiverId     String
  caregiver        CaregiverProfile @relation("MatchCaregiver", fields: [caregiverId], references: [id])
  status          String           @default("PENDING") // PENDING -> ACCEPTED -> CONFIRMED -> IN_PROGRESS -> COMPLETED
  serviceCategory String
  startDate       DateTime
  endDate         DateTime?
  schedule        String           @default("[]")
  specialRequests String?
  estimatedRate   Int?
  requestedAt     DateTime         @default(now())
  respondedAt     DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     InterviewMessage[]
  careSessions CareSession[]
  recipients   MatchRecipient[]
  contract     Contract?

  @@index([guardianId])
  @@index([caregiverId])
  @@index([status])
}

model MatchRecipient {
  id              String        @id @default(cuid())
  matchId         String
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  careRecipientId String
  careRecipient   CareRecipient @relation(fields: [careRecipientId], references: [id])

  @@unique([matchId, careRecipientId])
}

// ─── Contract (표준 계약서) ───

model Contract {
  id               String   @id @default(cuid())
  matchId          String   @unique
  match            Match    @relation(fields: [matchId], references: [id])
  serviceCategory  String
  hourlyRate       Int
  schedule         String   @default("[]") // JSON
  startDate        DateTime
  endDate          DateTime?
  specialTerms     String?
  guardianSigned   Boolean  @default(false)
  guardianSignedAt DateTime?
  caregiverSigned  Boolean  @default(false)
  caregiverSignedAt DateTime?
  status           String   @default("DRAFT") // DRAFT, PENDING_SIGN, ACTIVE, TERMINATED, EXPIRED
  terminatedAt     DateTime?
  terminationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Chat (채팅) ───

model InterviewMessage {
  id          String  @id @default(cuid())
  matchId     String
  match       Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User    @relation(fields: [senderId], references: [id])
  content     String
  messageType String  @default("TEXT") // TEXT, IMAGE, FILE, SYSTEM, CONTRACT
  imageUrl    String?
  fileName    String?
  fileUrl     String?
  isRead      Boolean @default(false)
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
  @@index([senderId])
}

// ─── Care Session (돌봄 세션) ───

model CareSession {
  id            String           @id @default(cuid())
  matchId       String
  match         Match            @relation(fields: [matchId], references: [id])
  caregiverId   String
  caregiver     CaregiverProfile @relation("CareSessionCaregiver", fields: [caregiverId], references: [id])
  status        String           @default("SCHEDULED")
  scheduledDate DateTime
  startTime     String
  endTime       String
  actualStart   DateTime?
  actualEnd     DateTime?
  hourlyRate    Int
  totalHours    Float?
  totalAmount   Int?
  notes         String?
  // GPS Check-in/out
  checkInLat    Float?
  checkInLng    Float?
  checkInTime   DateTime?
  checkOutLat   Float?
  checkOutLng   Float?
  checkOutTime  DateTime?
  checkInAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipients CareSessionRecipient[]
  journals   Journal[]
  review     Review?
  settlement Settlement?

  @@index([matchId])
  @@index([caregiverId])
  @@index([scheduledDate])
}

model CareSessionRecipient {
  id              String        @id @default(cuid())
  careSessionId   String
  careSession     CareSession   @relation(fields: [careSessionId], references: [id], onDelete: Cascade)
  careRecipientId String
  careRecipient   CareRecipient @relation(fields: [careRecipientId], references: [id])

  @@unique([careSessionId, careRecipientId])
}

// ─── Journal (돌봄일지) ───

model Journal {
  id              String      @id @default(cuid())
  careSessionId   String
  careSession     CareSession @relation(fields: [careSessionId], references: [id], onDelete: Cascade)
  title           String
  content         String
  activities      String      @default("[]")
  mood            String?
  meals           String?
  bloodPressure   String?
  bloodSugar      Int?
  temperature     Float?
  waterIntake     Int?
  bowelMovement   String?
  medicationTaken Boolean     @default(false)
  exerciseLog     String?
  mentalState     String?
  sleepQuality    String?
  images          String      @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([careSessionId])
}

// ─── Settlement (정산) ───

model Settlement {
  id            String      @id @default(cuid())
  careSessionId String      @unique
  careSession   CareSession @relation(fields: [careSessionId], references: [id])
  caregiverId   String
  caregiver     CaregiverProfile @relation(fields: [caregiverId], references: [id])
  amount        Int         // 총 금액
  platformFee   Int         @default(0) // 플랫폼 수수료 (3%)
  netAmount     Int         // 실수령액
  status        String      @default("PENDING") // PENDING, CONFIRMED, DISPUTED, PAID, CANCELLED
  confirmedAt   DateTime?
  disputedAt    DateTime?
  disputeReason String?
  paidAt        DateTime?
  paidMethod    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caregiverId])
  @@index([status])
}

// ─── Review (리뷰) ───

model Review {
  id              String           @id @default(cuid())
  careSessionId   String           @unique
  careSession     CareSession      @relation(fields: [careSessionId], references: [id])
  authorId        String
  author          GuardianProfile  @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId        String
  target          CaregiverProfile @relation("ReviewTarget", fields: [targetId], references: [id])
  overallRating   Int
  punctuality     Int?
  attitude        Int?
  professionalism Int?
  communication   Int?
  healthCareSkill Int?
  kindness        Int?
  trust           Int?
  content         String
  tags            String           @default("[]")
  images          String           @default("[]")
  isVisible       Boolean          @default(true)
  isReported      Boolean          @default(false)
  reportReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetId])
  @@index([authorId])
}

// ─── Bookmark (즐겨찾기) ───

model Bookmark {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  caregiverId String
  caregiver   CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, caregiverId])
  @@index([userId])
}

// ─── Community (커뮤니티) ───

model CommunityPost {
  id        String  @id @default(cuid())
  authorId  String
  title     String
  content   String
  category  String
  images    String  @default("[]")
  viewCount Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes    CommunityLike[]
  comments CommunityComment[]

  @@index([category])
  @@index([createdAt])
}

model CommunityLike {
  id     String        @id @default(cuid())
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model CommunityComment {
  id       String        @id @default(cuid())
  postId   String
  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  content  String
  isActive Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
}

// ─── Notification (알림) ───

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  link       String?
  isRead     Boolean  @default(false)
  readAt     DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Emergency SOS ───

model EmergencySOS {
  id            String  @id @default(cuid())
  userId        String
  careSessionId String?
  latitude      Float?
  longitude     Float?
  status        String  @default("ACTIVE") // ACTIVE, RESOLVED, FALSE_ALARM
  resolvedAt    DateTime?
  notes         String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ─── Emergency Care (긴급 돌봄 요청) ───

model EmergencyCare {
  id              String           @id @default(cuid())
  guardianId      String
  guardian        GuardianProfile  @relation(fields: [guardianId], references: [id])
  careRecipientId String?
  careDate        DateTime
  startTime       String
  durationHours   Int
  serviceType     String           @default("HOME_CARE") // HOME_CARE, HOSPITAL_CARE, DAILY_CARE
  address         String?
  specialNotes    String?
  status          String           @default("PENDING") // PENDING, MATCHED, EXPIRED, CANCELLED
  expiresAt       DateTime
  matchedAt       DateTime?
  cancelledAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches EmergencyCareMatch[]

  @@index([guardianId])
  @@index([status])
}

model EmergencyCareMatch {
  id               String           @id @default(cuid())
  emergencyCareId  String
  emergencyCare    EmergencyCare    @relation(fields: [emergencyCareId], references: [id], onDelete: Cascade)
  caregiverId      String
  caregiver        CaregiverProfile @relation(fields: [caregiverId], references: [id])
  status           String           @default("SENT") // SENT, VIEWED, ACCEPTED, REJECTED
  sentAt           DateTime         @default(now())
  respondedAt      DateTime?

  @@unique([emergencyCareId, caregiverId])
  @@index([emergencyCareId])
  @@index([caregiverId])
}

// ─── Pass (이용권) ───

model Pass {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      PassType
  total     Int       // 총 횟수
  remaining Int       // 남은 횟수
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([type])
}

enum PassType {
  SINGLE // 1회 이용권 3,900원
  FIVE   // 5회 이용권 15,000원
  TEN    // 10회 이용권 25,000원
}

// ─── Subscription (구독) ───

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

enum SubscriptionPlan {
  STANDARD // 29,900원/월
  PREMIUM  // 59,900원/월
  FAMILY   // 99,900원/월
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

// ─── Payment (결제) ───

model Payment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Int
  method      String?       // 결제 수단
  status      PaymentStatus @default(PENDING)
  orderId     String        @unique // 주문번호
  paymentKey  String?       // PG 결제키
  productType String        // PASS_SINGLE, PASS_FIVE, PASS_TEN, SUB_STANDARD, SUB_PREMIUM, SUB_FAMILY
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ─── Admin: Notice (공지사항) ───

model Notice {
  id          String        @id @default(cuid())
  title       String
  content     String        @db.Text
  target      NoticeTarget  @default(ALL)
  isPinned    Boolean       @default(false)
  attachments String        @default("[]")
  status      NoticeStatus  @default(DRAFT)
  publishAt   DateTime?
  expiresAt   DateTime?
  viewCount   Int           @default(0)
  authorId    String
  author      User          @relation("NoticeAuthor", fields: [authorId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([target])
  @@index([isPinned])
}

enum NoticeTarget {
  ALL
  GUARDIAN
  CAREGIVER
}

enum NoticeStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  EXPIRED
}

// ─── Education (교육 콘텐츠) ───

model Education {
  id          String            @id @default(cuid())
  title       String
  description String            @db.Text
  category    EducationCategory
  duration    Int               // 분 단위
  isRequired  Boolean           @default(false)
  content     String            @db.Text // HTML 또는 마크다운
  quizzes     Json?             // 퀴즈 데이터
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  enrollments EducationEnrollment[]
}

enum EducationCategory {
  REQUIRED    // 필수 교육
  ADVANCED    // 전문 심화
  PRACTICAL   // 실무
  EMOTIONAL   // 정서/소통
}

model EducationEnrollment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  educationId  String
  education    Education @relation(fields: [educationId], references: [id])
  progress     Int       @default(0) // 0~100
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, educationId])
  @@index([userId])
  @@index([educationId])
}

// ─── Report (신고/분쟁) ───

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  targetId    String
  target      User         @relation("ReportTarget", fields: [targetId], references: [id])
  type        ReportType
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  resolution  String?      @db.Text
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
  @@index([type])
}

enum ReportType {
  INAPPROPRIATE_BEHAVIOR
  NO_SHOW
  FRAUD
  HARASSMENT
  QUALITY_ISSUE
  OTHER
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}

// ─── Institution (기관) ───

model Institution {
  id                String            @id @default(cuid())
  name              String
  businessNumber    String            @unique // 사업자등록번호
  ltcNumber         String?           // 장기요양기관번호
  type              String            // 재가요양/주야간보호/방문간호 등
  address           String
  phone             String
  representativeName String
  status            InstitutionStatus @default(PENDING)
  members           InstitutionMember[]
  staff             InstitutionStaff[]
  recipients        InstitutionRecipient[]
  claims            InstitutionClaim[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([businessNumber])
}

enum InstitutionStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

model InstitutionMember {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  role          InstitutionRole @default(STAFF)
  createdAt     DateTime    @default(now())

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

enum InstitutionRole {
  OWNER
  MANAGER
  STAFF
}

model InstitutionStaff {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  caregiverId   String
  caregiver     User        @relation("InstitutionCaregiver", fields: [caregiverId], references: [id])
  status        String      @default("ACTIVE")
  joinedAt      DateTime    @default(now())

  @@unique([institutionId, caregiverId])
  @@index([institutionId])
  @@index([caregiverId])
}

model InstitutionRecipient {
  id              String      @id @default(cuid())
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  name            String
  birthDate       String
  careLevel       String?     // 장기요양등급
  careType        String      // 서비스 유형
  assignedStaffId String?
  status          String      @default("ACTIVE")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([institutionId])
  @@index([assignedStaffId])
}

model InstitutionClaim {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  yearMonth     String      // "2026-03"
  totalAmount   Int
  status        ClaimStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId])
  @@index([yearMonth])
  @@index([status])
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  PAID
}
